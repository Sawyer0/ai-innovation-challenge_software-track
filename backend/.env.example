# Copy this file to .env and fill in your real values.
# Never commit .env — it is gitignored.

# --- AI Keys (required) ---
ANTHROPIC_API_KEY=sk-ant-...        # Claude — primary AI for advisement + transcript parsing
GEMINI_API_KEY=...                  # Gemini 2.5 Flash — fallback AI

# --- AI Models (optional, defaults shown) ---
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-flash

# --- Database (optional, defaults shown) ---
DATABASE_URL=sqlite:///./bmcc_catalog.db

# --- Server (optional, defaults shown) ---
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
